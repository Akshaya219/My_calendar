# ─────────────────────────────────────────────────────────────
#  StudySync — Environment Variables Template
#  Copy this file to .env.local and fill in your own values.
#  NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# Supabase project URL
# Found in: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key
# Found in: Supabase Dashboard → Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# App display name (used in page titles and notifications)
VITE_APP_NAME=StudySync
